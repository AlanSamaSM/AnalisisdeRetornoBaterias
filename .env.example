# =============================================================================
# Google Document AI - Configuración para OCR de recibos escaneados
# =============================================================================
# Solo necesario si los recibos son PDFs escaneados (imágenes).
# Para PDFs digitales (texto seleccionable), PyMuPDF funciona sin config.

# Ruta al archivo de credenciales del Service Account de GCP
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# ID del proyecto en Google Cloud Platform
GCP_PROJECT_ID=tu-proyecto-gcp

# Ubicación del procesador (us, eu)
GCP_LOCATION=us

# ID del procesador Document AI (crear en console.cloud.google.com)
GCP_PROCESSOR_ID=tu-processor-id
