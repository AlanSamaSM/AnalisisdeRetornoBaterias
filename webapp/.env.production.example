# ═══════════════════════════════════════════════════════════════
#  Variables de entorno para PRODUCCIÓN en Hostinger
#  Copiar estos valores al panel: Despliegues → Variables de entorno
# ═══════════════════════════════════════════════════════════════

# ── NextAuth ──
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=REEMPLAZAR_CON_STRING_ALEATORIO_32_CHARS

# URL pública de tu sitio en Hostinger (sin trailing slash)
NEXTAUTH_URL=https://papayawhip-clam-581861.hostingersite.com

# ── Base de datos PostgreSQL (Neon serverless) ──
# Obtener en: https://neon.tech → Crear proyecto → Connection string (direct)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ── Node ──
NODE_ENV=production
