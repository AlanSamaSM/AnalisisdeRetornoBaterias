# ── Auth ──
NEXTAUTH_SECRET=cambiar-por-un-secreto-seguro-de-32-chars
NEXTAUTH_URL=http://localhost:3000

# ── Base de datos (SQLite por defecto) ──
DATABASE_URL="file:./dev.db"

# ── Configuración del sistema ──
# Tasa de crecimiento tarifario anual (decimal)
TASA_CRECIMIENTO=0.08
# Tipo de cambio MXN/USD por defecto
TIPO_CAMBIO=18.50
