# ── Auth ──
NEXTAUTH_SECRET=cambiar-por-un-secreto-seguro-de-32-chars
NEXTAUTH_URL=http://localhost:3000

# ── Base de datos ──
# Desarrollo local (SQLite) — cambiar el provider en schema.prisma a 'sqlite':
# DATABASE_URL="file:./dev.db"
# Desarrollo/Producción (Neon PostgreSQL):
DATABASE_URL="postgresql://USER:PASS@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ── Configuración del sistema ──
# Tasa de crecimiento tarifario anual (decimal)
TASA_CRECIMIENTO=0.08
# Tipo de cambio MXN/USD por defecto
TIPO_CAMBIO=18.50
