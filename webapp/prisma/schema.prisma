// ─── Prisma Schema - BESS Analyzer (Desktop) ───
// SQLite local — sin autenticación, datos privados en disco

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./bess.db"
}

model Proyecto {
  id        String   @id @default(cuid())
  nombre    String
  cliente   String?
  estado    String   @default("")
  municipio String   @default("")
  region    String   @default("NORTE")
  tarifa    String   @default("GDMTH")
  notas     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Parámetros BESS
  potenciaKw     Float    @default(0)
  capacidadKwh   Float    @default(0)
  precioUsd      Float    @default(0)
  tipoCambio     Float    @default(18.50)
  aniosProyeccion Int     @default(15)
  eficiencia     Float    @default(0.90)
  horasCargaBase Int      @default(6)

  // Especificaciones del equipo BESS
  marcaBess           String  @default("")
  modeloBess          String  @default("")
  tecnologiaBess      String  @default("LFP")
  vidaUtilAnios       Int     @default(15)
  garantiaAnios       Int     @default(5)
  capacidadContratada Float   @default(0)
  integrador          String  @default("")
  preparadoPor        String  @default("")
  tasaDegradacion     Float   @default(0.02)
  ciclosAnuales       Int     @default(300)
  umbralRecompra      Float   @default(0.70)

  // Resultados calculados (JSON serializado)
  resultadosJson String?

  recibos Recibo[]
}

model Recibo {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  proyectoId String
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  archivoNombre String
  anio          Int
  mes           String
  mesNum        Int
  dias          Int
  temporada     String

  consumoPunta      Float @default(0)
  consumoIntermedia Float @default(0)
  consumoBase       Float @default(0)
  totalConsumo      Float @default(0)

  demandaPunta      Float @default(0)
  demandaIntermedia Float @default(0)
  demandaBase       Float @default(0)
  demandaMaxima     Float @default(0)

  factorCarga    Float @default(0)
  factorPotencia Float @default(0)
  cargoCapacidadRecibo Float @default(0) // $ importe Capacidad leído del recibo
  cargoDistribucion Float @default(0)    // $ importe Distribución leído del recibo
  cargoEnergiaPunta Float @default(0)    // $ importe Energía Punta leído del recibo
  cargoEnergiaIntermedia Float @default(0) // $ importe Energía Intermedia leído del recibo
  cargoEnergiaBase Float @default(0)     // $ importe Energía Base leído del recibo
  importeTotal Float @default(0)         // $ Total a Pagar del recibo CFE

  @@unique([proyectoId, mes, anio])
}
